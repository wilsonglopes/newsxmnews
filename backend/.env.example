# ============================================
#  Exemplo de configuração — copie para .env
# ============================================

# WordPress (para publicação de artigos)
WP_URL=https://seusite.com.br
WP_USER=seu_usuario_wordpress
WP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# IA — Reescrita de artigos (configure ao menos um)
GEMINI_KEY=AIzaxxxxxxxxxx
DEEPSEEK_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Custom Search — busca de imagem para matérias do Telegram (opcional)
# Crie a API Key em https://console.cloud.google.com/apis/credentials
# Crie o CSE (modo "Search the entire web" + "Image search ON") em https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Backend
BACKEND_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Banco de dados — Docker local (desenvolvimento)
DATABASE_URL=postgresql://rb24user:rb24pass@localhost:5432/rb24horas

# Banco de dados — Supabase (produção)
# DATABASE_URL=postgresql://postgres:SENHA@db.PROJETO.supabase.co:5432/postgres

# JWT
JWT_SECRET=troque_por_uma_string_aleatoria_longa
ENCRYPTION_KEY=troque_por_32_caracteres_exatos_
SESSION_EXPIRES_HOURS=168

# Sistema
ADMIN_EMAIL=admin@seusite.com.br
FETCH_INTERVAL_MINUTES=15
MAX_ARTICLES_PER_SOURCE=20
